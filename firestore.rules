rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper function to check if user is authenticated
    function isSignedIn() {
      return request.auth != null;
    }

    // Helper function to check if user is league admin
    function isLeagueAdmin(leagueId) {
      return isSignedIn() &&
             get(/databases/$(database)/documents/leagues/$(leagueId)).data.admin == request.auth.uid;
    }

    // Helper function to check if user is in the league
    // Uses memberUids flat array for efficient membership checks
    function isInLeague(leagueId) {
      return isSignedIn() &&
             request.auth.uid in get(/databases/$(database)/documents/leagues/$(leagueId)).data.memberUids;
    }

    // Helper to check if a user is banned from league chat
    function isChatBanned(leagueId) {
      return isSignedIn() &&
             exists(/databases/$(database)/documents/leagues/$(leagueId)/chatBans/$(request.auth.uid));
    }

    // Leagues collection
    match /leagues/{leagueId} {
      // Any authenticated user can read league docs (needed for league discovery)
      // Sensitive data is in subcollections which are gated to members
      allow read: if isSignedIn();

      // Only authenticated users can create leagues (they become admin)
      // Must include memberUids array
      allow create: if isSignedIn() &&
                      request.resource.data.admin == request.auth.uid &&
                      request.resource.data.memberUids is list;

      // Only league admin can update or delete
      allow update, delete: if isLeagueAdmin(leagueId);

      // Team scores - only league members can read, only admin can write
      match /teamScores/{scoreId} {
        allow read: if isInLeague(leagueId);
        allow write: if isLeagueAdmin(leagueId);
      }

      // Player daily scores - only league members can read
      match /playerDailyScores/{scoreId} {
        allow read: if isInLeague(leagueId);
        allow write: if isLeagueAdmin(leagueId);
      }

      // Season aggregates - per-team rollup of playerDailyScores for the
      // dashboard (read by members); cron writes via Admin SDK, admin deletes
      // them on Clear Scores.
      match /aggregates/{teamName} {
        allow read: if isInLeague(leagueId);
        allow write: if isLeagueAdmin(leagueId);
      }

      // Live stats - league members can read, only admin can write
      match /liveStats/{statId} {
        allow read: if isInLeague(leagueId);
        allow write: if isLeagueAdmin(leagueId);
      }

      // Processed dates - track which dates have been scored (idempotency)
      match /processedDates/{dateId} {
        allow read: if isInLeague(leagueId);
        allow write: if isLeagueAdmin(leagueId);
      }

      // Chat bans - only league admin can manage banned users
      match /chatBans/{userId} {
        allow read, write: if isLeagueAdmin(leagueId);
      }

      // League chat messages - simple league-wide chat
      match /chatMessages/{messageId} {
        allow read: if isInLeague(leagueId);
        allow create: if isInLeague(leagueId) && !isChatBanned(leagueId);
        allow delete, update: if isLeagueAdmin(leagueId);
      }

      // Private league data (e.g. the current invite code). Admin may read; only
      // the Admin SDK writes it.
      match /private/{doc} {
        allow read: if isLeagueAdmin(leagueId);
        allow write: if false;
      }

      // Public-league join requests: a user creates/cancels their own request; the
      // league admin reads them and deletes on approve/deny.
      match /joinRequests/{requesterUid} {
        allow read:   if isLeagueAdmin(leagueId) || request.auth.uid == requesterUid;
        allow create: if isSignedIn()
                        && request.auth.uid == requesterUid
                        && request.resource.data.uid == requesterUid;
        allow delete: if isLeagueAdmin(leagueId) || request.auth.uid == requesterUid;
      }
    }

    // Drafted players - linked to specific league
    match /draftedPlayers/{playerId} {
      // Any authenticated user can read (player names/picks aren't sensitive)
      allow read: if isSignedIn();

      // Only league members can draft players
      allow create: if isSignedIn() &&
                      request.resource.data.leagueId != null &&
                      isInLeague(request.resource.data.leagueId);

      // Only league admin can delete (for draft reset)
      allow delete: if isSignedIn() &&
                      resource.data.leagueId != null &&
                      isLeagueAdmin(resource.data.leagueId);

      // Only league members can update roster slots
      allow update: if isSignedIn() &&
                      resource.data.leagueId != null &&
                      isInLeague(resource.data.leagueId) &&
                      request.resource.data.diff(resource.data).affectedKeys().hasOnly(['rosterSlot', 'pendingSlot', 'lastSwapDate']);
    }

    // Draft state - per league
    // Members need write access to advance picks during drafting (transaction in NHLRoster)
    match /drafts/{leagueId} {
      allow read: if isInLeague(leagueId);
      allow create, update: if isInLeague(leagueId);
      allow delete: if isLeagueAdmin(leagueId);
    }

    // NHL Daily Stats - Global collection for stats cache
    // Only writable via Admin SDK (server-side cron jobs)
    match /nhl_daily_stats/{date} {
      allow read: if isSignedIn();
      allow write: if false;
    }

    // Invite code → leagueId mapping. Server (Admin SDK) only; never client-readable
    // so codes can't be enumerated from the world-readable league docs.
    match /inviteCodes/{code} {
      allow read, write: if false;
    }

    // Deny everything else by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
